{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "permissions": {
    "allow": [
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(gh issue:*)",
      "Bash(gh auth status:*)",
      "Bash(jj workspace:*)",
      "Bash(jj git init:*)",
      "Bash(jj log:*)",
      "Bash(jj status:*)",
      "Bash(lark-cli:*)",
      "Bash(jq:*)",
      "Bash(python3 -c:*)",
      "Bash(bash -n:*)",
      "Bash(chmod +x:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(test:*)",
      "Bash(readlink:*)",
      "Bash(stat:*)",
      "Bash(mkdir:*)",
      "Bash(ln -sf:*)",
      "Edit(./docs/**)",
      "Edit(./.workflow-state.json)",
      "Edit(./.onboard-state.json)",
      "Edit(./.agentic-workflows/**)",
      "Write(./docs/**)",
      "Write(./.workflow-state.json)",
      "Write(./.onboard-state.json)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(gh pr merge:*)"
    ]
  },
  "autoMode": {
    "environment": [
      "$defaults",
      "Trusted internal services: Lark/Feishu (open.larksuite.com, open.feishu.cn) — `lark-cli` calls are workflow infrastructure, not external network egress.",
      "Symlinked dirs from JJ secondary workspaces (docs/, .agentic-workflows/, .agents/, .claude/) point to the sibling primary workspace by design. Treat writes through them as in-scope."
    ]
  }
}
